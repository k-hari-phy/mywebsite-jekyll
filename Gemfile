source "https://rubygems.org"

# Modern Jekyll version that runs perfectly on Ruby 4.0
gem "jekyll", "~> 4.3"

# Complete plugin suite for academic templates
gem "jekyll-feed", "~> 0.12"
gem "jekyll-seo-tag", "~> 2.8"
gem "jekyll-sitemap", "~> 1.4"
gem "jekyll-include-cache", "~> 0.2"
gem "jekyll-gist", "~> 1.5"
gem "jekyll-paginate", "~> 1.1"
gem "jekyll-redirect-from", "~> 0.16" 
gem "jekyll-archives", "~> 2.2"      
gem "jemoji", "~> 0.12"

# Windows-specific patches for Ruby 4.0
gem "webrick", "~> 1.8"
gem "csv", "~> 3.3"
gem "bigdecimal", "~> 3.1"

# Explicitly load core timezone components for Windows environments
gem "tzinfo", "~> 2.0"
gem "tzinfo-data", platforms: [:windows, :jruby]